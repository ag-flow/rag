# Configuration ag-flow.rag — dev/test (M1)
# Spec : docs/superpowers/specs/2026-05-14-rag-mvp-implementation-design.md

# ─── PostgreSQL (base rag_config) ───────────────────────────
POSTGRES_USER=rag
POSTGRES_PASSWORD=
POSTGRES_DB=rag_config
DATABASE_URL=postgresql://rag:${POSTGRES_PASSWORD}@postgres:5432/rag_config
RAG_POSTGRES_ADMIN_URL=postgresql://rag:${POSTGRES_PASSWORD}@postgres:5432/postgres

# ─── Master key API (Bearer admin) ──────────────────────────
RAG_MASTER_KEY=

# ─── URL publique ───────────────────────────────────────────
# Remplacer par l'URL externe de la stack (IP du LXC, FQDN, ou http://localhost en dev).
RAG_PUBLIC_URL=http://localhost

# ─── Harpocrate (résolution secrets ${vault://...}) ────────
# Depuis M5c : coffres configurables exclusivement via l'IHM
# /ui/settings/harpocrate-vaults (ou POST /api/admin/harpocrate-vaults).
#
# HARPOCRATE_DEK : passphrase pgcrypto utilisée pour chiffrer les api_keys
# des coffres en base. Min 32 caractères. OBLIGATOIRE dès qu'un coffre est
# créé via l'IHM ou l'API admin.
# Note docker-compose : doubler tout $ en $$ si déposé via env_file.
HARPOCRATE_DEK=

# ─── Reranking (M8) ──────────────────────────────────────────────────────────
#
# Les clés API des providers de reranking (Cohere / Voyage) sont stockées
# dans Harpocrate, jamais en `.env`. La table `rerank_configs` référence
# une `api_key_ref` (clé logique Harpocrate) par workspace.
#
# Ollama : pas d'api_key, juste un `base_url` (ex. http://localhost:11434).
#
# Aucune variable d'env spécifique au rerank côté serveur — tout est
# configuré via PUT /api/admin/workspaces/{name}/rerank.

# ─── Divers ─────────────────────────────────────────────────
ENVIRONMENT=dev
LOG_LEVEL=INFO
SYNC_WORKER_POLL_INTERVAL_SECONDS=30

# ─── Sync worker M3 ─────────────────────────────────────────
# Interval défaut entre 2 syncs d'une même source (sec). Override possible
# par source via config.sync_interval_seconds. Min 60s.
SYNC_DEFAULT_INTERVAL_SECONDS=300
# Racine des clones git locaux (volume Docker named en prod).
SYNC_REPOS_ROOT=/var/lib/rag/repos

# ─── Bootstrap admin local (M5b) ─────────────────────────────────────────────
#
# Compte admin local de secours pour se logger dans l'IHM AVANT que OIDC ne
# soit configuré. Permet d'accéder à la page /ui/settings/oidc-config et de
# paramétrer Keycloak depuis l'IHM elle-même (sans curl + master-key).
#
# Activation : bootstrap actif tant que RAG_BOOTSTRAP_ADMIN_PASSWORD_HASH
# est non vide. Pour désactiver, vider cette variable et redémarrer.
#
# Initialisation : `dev-deploy.sh` génère automatiquement un pwd aléatoire
# et son hash bcrypt si la variable est vide, et affiche le pwd en console
# (à noter au premier déploiement).
#


# Password en clair pour memo dev (lecture humaine). Le backend ne lit PAS
# cette variable — seul RAG_BOOTSTRAP_ADMIN_PASSWORD_HASH est utilise.
# Generé automatiquement par dev-deploy.sh, à supprimer manuellement en prod.
# TTL session locale en secondes (defaut 28800 = 8h).
RAG_BOOTSTRAP_ADMIN_USERNAME=admin
RAG_BOOTSTRAP_ADMIN_PASSWORD_PLAIN=
RAG_BOOTSTRAP_ADMIN_PASSWORD_HASH=                                                            
RAG_BOOTSTRAP_SESSION_TTL_SECONDS=28800