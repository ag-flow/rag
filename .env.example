# Configuration ag-flow.rag — dev/test
# Les variables vides sont renseignées automatiquement par dev-deploy.sh
# au premier lancement (création du .env à partir de ce fichier).

# ─── PostgreSQL ─────────────────────────────────────────────
POSTGRES_USER=rag
POSTGRES_PASSWORD=
POSTGRES_DB=rag_config
DATABASE_URL=postgresql://rag:${POSTGRES_PASSWORD}@postgres:5432/rag_config

# ─── Master key API (administration via Bearer token) ───────
# Spec : specs/02-api-admin.md. Distincte de l'admin local OIDC.
RAG_MASTER_KEY=

# ─── URL publique (frontend, redirects OIDC callback) ───────
# Auto-détectée par dev-deploy.sh (IP eth0 + port HTTPS du compose).
RAG_PUBLIC_URL=

# ─── HMAC (signature de tokens internes / api keys workspace) ─
# Générée par dev-deploy.sh au premier run (base64 de 32 bytes).
RAG_HMAC_KEY=

# ─── Admin local (compte de secours, fallback si OIDC KO) ───
# Passé à true par dev-deploy.sh au premier run + password généré.
RAG_ADMIN_LOCAL_ENABLED=false
RAG_ADMIN_LOCAL_USERNAME=admin
RAG_ADMIN_LOCAL_PASSWORD=

# ─── Keycloak OIDC (auth IHM /ui) ───────────────────────────
# Si non renseigné, l'IHM /ui est désactivée mais l'API REST/MCP fonctionne.
# Spec : specs/10-auth.md.
RAG_KEYCLOAK_URL=
RAG_KEYCLOAK_REALM=homelab
RAG_KEYCLOAK_CLIENT_ID=rag-service
# Le client_secret OIDC est résolu via Harpocrate au démarrage, jamais stocké
# en clair. La valeur ci-dessous est la clé logique opaque côté Harpocrate.
RAG_KEYCLOAK_CLIENT_SECRET_REF=keycloak_rag_client_secret

# ─── Listmonk (envoi mails recovery / notifications) ────────
# Optionnel — si non renseigné, les mails sont désactivés.
RAG_LISTMONK_URL=
RAG_LISTMONK_USERNAME=
RAG_LISTMONK_PASSWORD=
RAG_LISTMONK_LIST_ID=

# ─── Harpocrate (résolution des secrets ${vault://...}) ─────
# Au moins une API key Harpocrate doit être attribuée au service.
# Format : HARPOCRATE_API_TOKEN_<ID>=hrpv_1_...
#          HARPOCRATE_API_URL_<ID>=https://vault.yoops.org
# Spec : specs/vault.md + specs/internal_resolution-formalism.md.
HARPOCRATE_API_TOKEN_RAG=
HARPOCRATE_API_URL_RAG=https://vault.yoops.org

# ─── Divers ─────────────────────────────────────────────────
ENVIRONMENT=dev
LOG_LEVEL=INFO
