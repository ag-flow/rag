# ag-flow.rag — Configuration de production
# ============================================================
# Copier ce fichier en .env et remplir chaque valeur.
# Ne jamais commiter .env dans git.
#
# Référence complète : docs/deploy.md
# ============================================================


# ────────────────────────────────────────────────────────────
# IMAGE TAG
# ────────────────────────────────────────────────────────────
# Tag des images GHCR à déployer.
# Exemples :
#   latest       → dernière image fusionnée sur main (pipeline CI)
#   abc1234      → SHA Git court pour un déploiement épinglé
#
# Pour connaître le tag exact d'un build CI :
#   https://github.com/ag-flow/rag/pkgs/container/rag-backend
#
IMAGE_TAG=latest

# SHA Git injecté dans /version (optionnel — cosmétique uniquement).
# Laisser vide pour afficher "unknown".
GIT_SHA=


# ────────────────────────────────────────────────────────────
# POSTGRESQL
# ────────────────────────────────────────────────────────────
# Identifiants du superutilisateur Postgres créé au premier démarrage.
# Ces variables ne sont lues par Postgres qu'à l'initialisation du volume
# (volume vierge). Elles doivent rester cohérentes avec DATABASE_URL.
#
POSTGRES_USER=rag
POSTGRES_PASSWORD=                # Générer : openssl rand -hex 24
POSTGRES_DB=rag_config

# DSN applicatif — utilisé par le backend (asyncpg).
# Format : postgresql://<user>:<password>@postgres:5432/<db>
DATABASE_URL=postgresql://rag:CHANGEME@postgres:5432/rag_config

# DSN admin — utilisé pour créer les bases workspace et appliquer les migrations.
# Pointe sur la base "postgres" (superutilisateur requis pour CREATE DATABASE).
RAG_POSTGRES_ADMIN_URL=postgresql://rag:CHANGEME@postgres:5432/postgres


# ────────────────────────────────────────────────────────────
# CLÉS ET SECRETS
# ────────────────────────────────────────────────────────────

# Master key — authentifie les appels Bearer sur /api/admin/*.
# Longueur minimale : 32 caractères. Traiter comme un mot de passe root.
# Générer : openssl rand -hex 32
RAG_MASTER_KEY=

# Secret de session OIDC — signe les cookies _oidc_session.
# Longueur minimale : 32 caractères. Indépendant de RAG_MASTER_KEY en prod.
# Générer : openssl rand -hex 32
RAG_SESSION_SECRET=

# Clé de chiffrement pgcrypto pour les api_keys des coffres Harpocrate.
# Longueur minimale : 32 caractères. OBLIGATOIRE dès qu'un coffre est
# configuré via l'IHM (/ui/settings/harpocrate-vaults).
# Perte = perte de toutes les clés API stockées → sauvegarder hors Docker.
# Générer : openssl rand -hex 32
HARPOCRATE_DEK=

# Secret HMAC pour signer les payloads webhook (header X-RAG-Signature).
# Optionnel — si absent, les webhooks sont envoyés sans signature (warning log).
# Générer : openssl rand -hex 32
RAG_WEBHOOK_SECRET=


# ────────────────────────────────────────────────────────────
# URL PUBLIQUE
# ────────────────────────────────────────────────────────────
# URL externe de l'application, telle que vue par les navigateurs et les
# callbacks OIDC. Inclure le schéma, sans slash final.
# Exemples :
#   https://rag.yoops.org    (FQDN via Cloudflare Tunnel)
#   http://192.168.10.201    (IP LAN si pas de reverse proxy externe)
#
RAG_PUBLIC_URL=https://rag.example.com


# ────────────────────────────────────────────────────────────
# COMPTE ADMIN LOCAL (bootstrap)
# ────────────────────────────────────────────────────────────
# Compte de secours pour se connecter à l'IHM avant que Keycloak/OIDC
# ne soit configuré. Désactiver après avoir paramétré OIDC en laissant
# RAG_BOOTSTRAP_ADMIN_PASSWORD_HASH vide et en redémarrant.
#
# Nom d'utilisateur et email du compte local (modifiables).
RAG_BOOTSTRAP_ADMIN_USERNAME=admin
RAG_BOOTSTRAP_ADMIN_EMAIL=admin@rag.example.com

# Hash bcrypt du mot de passe admin. Obligatoire pour activer le bootstrap.
# Générer (Python) :
#   python3 -c "import bcrypt; print(bcrypt.hashpw(b'MON_MDP', bcrypt.gensalt(12)).decode())"
# Générer (htpasswd) :
#   htpasswd -bnBC 12 "" MON_MDP | tr -d ':\n'
#
RAG_BOOTSTRAP_ADMIN_PASSWORD_HASH=

# Durée de vie d'une session locale en secondes (défaut : 28 800 = 8 h).
RAG_BOOTSTRAP_SESSION_TTL_SECONDS=28800


# ────────────────────────────────────────────────────────────
# CADDY — PORT HTTP
# ────────────────────────────────────────────────────────────
# Port hôte exposé par Caddy. Cloudflare Tunnel pointe sur ce port.
# Valeur par défaut : 80. Changer si le port 80 est déjà occupé sur l'hôte.
#
CADDY_HTTP_PORT=80


# ────────────────────────────────────────────────────────────
# PRICING PROVIDERS EMBEDDING
# ────────────────────────────────────────────────────────────
# Chemin absolu (ou relatif au répertoire d'exécution du compose) vers le
# fichier YAML de tarifs des providers d'embedding.
# Ce fichier est disponible dans le dépôt :
#   https://github.com/ag-flow/rag/blob/main/embedding_providers_pricing.yml
#
# Télécharger sur l'hôte :
#   curl -Lo ./embedding_providers_pricing.yml \
#     https://raw.githubusercontent.com/ag-flow/rag/main/embedding_providers_pricing.yml
#
PRICING_FILE_HOST_PATH=./embedding_providers_pricing.yml


# ────────────────────────────────────────────────────────────
# SYNC WORKER
# ────────────────────────────────────────────────────────────
# Intervalle de polling du worker (secondes). Min 60.
SYNC_WORKER_POLL_INTERVAL_SECONDS=30

# Intervalle par défaut entre deux syncs d'une source git (secondes). Min 60.
SYNC_DEFAULT_INTERVAL_SECONDS=300


# ────────────────────────────────────────────────────────────
# LOGS
# ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
