# Template pour scripts/.env.test.rag (gitignored).
#
# Copier ce fichier vers `scripts/.env.test.rag` puis remplir les valeurs
# locales (notamment HARPOCRATE_API_TOKEN_RAG fourni hors-ligne).
#
# Le fichier `.env.test.rag` est :
#   1. copié par run-test.sh vers pve:/opt/scripts/.env.test.rag
#   2. sourcé par test-create-lxc.sh (lecture des vars de config runner)
#   3. (à venir) poussé dans le LXC test créé, pour propagation au .env du
#      backend via dev-deploy.sh.

# ─── Config runner test-create-lxc.sh ───────────────────────────────────────
GIT_REPO="ag-flow/rag"
GIT_BRANCH="dev"
APP_DIR="/opt/agflow.rag"
DEPLOY_SCRIPT="./dev-deploy.sh"

CTID_MIN=400
CTID_MAX=499
SCRIPTS_DIR="/opt/scripts"

# ─── Secrets à propager au .env du backend dans le LXC test ─────────────────
# Le token Harpocrate du projet RAG (préfixe `hrpv_...`). Fourni hors-ligne.
HARPOCRATE_API_TOKEN_RAG=
